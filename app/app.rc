#include "resource.h"
#include <afxres.h>
#include <afxribbonres.h>   // IDs for the framework's ribbon/pane context-menu strings

#pragma code_page(65001)    // the .rc is saved as UTF-8; let rc.exe read Polish diacritics

/////////////////////////////////////////////////////////////////////////////
// Menu  (SDI needs IDR_MAINFRAME as the shared menu; the ribbon hides it at runtime)

IDR_MAINFRAME MENU
BEGIN
    POPUP "&Plik"
    BEGIN
        MENUITEM "Za&kończ",                    ID_APP_EXIT
    END
    POPUP "&Edycja"
    BEGIN
        MENUITEM "&Cofnij\tCtrl+Z",             ID_EDIT_UNDO
        MENUITEM "&Ponów\tCtrl+Y",              ID_EDIT_REDO
    END
    POPUP "&Magazyn"
    BEGIN
        MENUITEM "&Odśwież\tF5",                ID_STOCK_REFRESH
        MENUITEM SEPARATOR
        MENUITEM "Przyjmij (&IN)...",           ID_STOCK_RECORD_IN
        MENUITEM "Wydaj (&OUT)...",             ID_STOCK_RECORD_OUT
        MENUITEM SEPARATOR
        MENUITEM "Tylko &niskie stany",         ID_STOCK_FILTER_LOW
    END
END

/////////////////////////////////////////////////////////////////////////////
// Accelerator

IDR_MAINFRAME ACCELERATORS
BEGIN
    VK_F5,          ID_STOCK_REFRESH,       VIRTKEY
    "Z",            ID_EDIT_UNDO,           VIRTKEY, CONTROL
    "Y",            ID_EDIT_REDO,           VIRTKEY, CONTROL
END

/////////////////////////////////////////////////////////////////////////////
// Dialog

IDD_RECORD_MOVEMENT DIALOGEX 0, 0, 264, 118
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Ruch magazynowy"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Produkt:",IDC_LBL_PRODUCT,12,16,48,10
    COMBOBOX        IDC_PRODUCT,66,14,186,100,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Magazyn:",IDC_LBL_WAREHOUSE,12,38,48,10
    COMBOBOX        IDC_WAREHOUSE,66,36,186,100,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Ilość:",IDC_LBL_QTY,12,62,48,10
    EDITTEXT        IDC_QTY,66,60,64,14,ES_AUTOHSCROLL | ES_NUMBER
    DEFPUSHBUTTON   "OK",IDOK,146,96,50,15
    PUSHBUTTON      "Anuluj",IDCANCEL,202,96,50,15
END

/////////////////////////////////////////////////////////////////////////////
// Ribbon icon strips (32-bit ARGB, alpha-blended by CMFCToolBarImages)

IDB_RIBBON_MAGAZYN_16 BITMAP "res\\ribbon_magazyn_16.bmp"
IDB_RIBBON_MAGAZYN_32 BITMAP "res\\ribbon_magazyn_32.bmp"
IDB_RIBBON_WIDOK_16   BITMAP "res\\ribbon_widok_16.bmp"
IDB_RIBBON_WIDOK_32   BITMAP "res\\ribbon_widok_32.bmp"

/////////////////////////////////////////////////////////////////////////////
// String Table

STRINGTABLE
BEGIN
    IDR_MAINFRAME           "Stany Magazynowe\n\nWarehouse\n\n\nWarehouse.Document\nWarehouse Document"
    ID_STOCK_REFRESH        "Przeładuj bieżące stany z bazy\nOdśwież"
    ID_STOCK_RECORD_IN      "Zarejestruj przyjęcie (IN)\nPrzyjmij"
    ID_STOCK_RECORD_OUT     "Zarejestruj wydanie (OUT)\nWydaj"
    ID_STOCK_FILTER_LOW     "Pokaż tylko pozycje poniżej progu\nFiltr niskich stanów"
    ID_THEME_MENU           "Wybierz motyw kolorystyczny\nMotyw"
END

// Polish overrides for the MFC Feature Pack context menus (dockable-pane and ribbon
// Quick Access Toolbar). These IDs belong to the shared MFC DLL; the app's copies take
// precedence when the framework resolves the resource through this module.
STRINGTABLE
BEGIN
    IDS_AFXBARRES_FLOATING              "Pływające"
    IDS_AFXBARRES_DOCKING               "Zadokowane"
    IDS_AFXBARRES_TABBED                "Dokument w kartach"
    IDS_AFXBARRES_AUTOHIDE              "Autoukrywanie"
    IDS_AFXBARRES_HIDE                  "Ukryj"
    IDS_AFXBARRES_ADD_TO_QAT           "Dodaj do paska szybkiego dostępu"
    IDS_AFXBARRES_REMOVE_FROM_QAT      "Usuń z paska szybkiego dostępu"
    IDS_AFXBARRES_CUSTOMIZE_QAT        "Dostosuj pasek szybkiego dostępu..."
    IDS_AFXBARRES_MINIMIZE_RIBBON      "Minimalizuj Wstążkę"
    IDS_AFXBARRES_PLACE_QAT_BELOW_RIBBON "Pokaż pasek szybkiego dostępu pod Wstążką"
    IDS_AFXBARRES_PLACE_QAT_ABOVE_RIBBON "Pokaż pasek szybkiego dostępu nad Wstążką"
END
